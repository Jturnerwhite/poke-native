{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ], 
      "@/components": [
        "./app/components/index.tsx"
      ],
      "@/components/*": [
        "./app/components/*"
      ],
      "@/queries/*": [
        "./app/queries/*"
      ],
      "@/types/*": [
        "./app/types/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts"
  ]
}
